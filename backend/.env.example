PORT=3001
NODE_ENV=development

# Firebase Admin — caminho para JSON da service account OU use GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_APPLICATION_CREDENTIALS=

# Opcional: projeto Firebase (se usar credenciais embutidas)
# FIREBASE_PROJECT_ID=

# WhatsApp (Meta Cloud API ou provedor compatível)
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Token de verificação do webhook (Meta)
WHATSAPP_VERIFY_TOKEN=

# Twilio WhatsApp (opcional; se preenchido, provider usa Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Ex: whatsapp:+14155238886 (sandbox) ou seu número WhatsApp Twilio
TWILIO_WHATSAPP_FROM=

# Janela do lembrete em minutos (scheduler a cada 5 min)
REMINDER_WINDOW_MINUTES=10
