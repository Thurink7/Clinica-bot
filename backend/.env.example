PORT=3001
NODE_ENV=development

# Autenticação do painel (JWT). Em produção use um segredo forte e único.
JWT_SECRET=

# Opcional: cria o primeiro usuário no Firestore (coleção admin_users) se ainda não existir.
# ADMIN_BOOTSTRAP_EMAIL=admin@clinica.com
# ADMIN_BOOTSTRAP_PASSWORD=sua-senha-segura
# ADMIN_BOOTSTRAP_NOME=Administrador

# Opcional: origens extras permitidas pelo CORS (separadas por vírgula)
# CORS_ORIGINS=https://meu-app.vercel.app

# Firebase Admin — escolha UMA das opções:
#
# 1) Local: caminho absoluto para o arquivo JSON baixado do Firebase
GOOGLE_APPLICATION_CREDENTIALS=
#
# 2) Render / VPS: cole o JSON inteiro em uma linha (cuidado com aspas no painel)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# 3) Render / VPS: JSON em Base64 (uma linha, prático no painel)
# FIREBASE_SERVICE_ACCOUNT_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
#
# (Alternativa) GOOGLE_APPLICATION_CREDENTIALS_JSON= igual ao (2)

# WhatsApp (Meta Cloud API ou provedor compatível)
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Token de verificação do webhook (Meta)
WHATSAPP_VERIFY_TOKEN=

# Twilio WhatsApp (opcional; se preenchido, provider usa Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Ex: whatsapp:+14155238886 (sandbox) ou seu número WhatsApp Twilio
TWILIO_WHATSAPP_FROM=

# Janela do lembrete em minutos (scheduler a cada 5 min)
REMINDER_WINDOW_MINUTES=10
